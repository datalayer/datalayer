{
  "name": "@datalayer/lab-material-ui",
  "description": "Sample User Interface in React.js with Typescript.",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "author": "Datalayer",
  "scripts": {
    "build": "tsc && BUILD_MODE=none webpack",
    "build:prod": "tsc && BUILD_MODE=production webpack",
    "clean": "rimraf lib dist build",
    "now-build": "tsc && BUILD_MODE=production webpack",
    "prepublishOnly": "BUILD_MODE=none npm run build",
    "start": "webpack-dev-server",
    "watch": "concurrently --kill-others \"tsc -w\" \"BUILD_MODE=none webpack --watch\" \"webpack-dev-server\""
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,eot,gif,html,jpg,json,png,svg,woff2,ttf}",
    "images/**/*.{css,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "dependencies": {
    "@material-ui/core": "4.6.1",
    "@material-ui/icons": "4.5.1",
    "@material-ui/lab": "4.0.0-alpha.32",
    "es6-promise": "4.2.8",
    "prop-types": "15.7.2",
    "react": "16.11.0",
    "react-dom": "16.11.0"
  },
  "devDependencies": {
    "@types/prop-types": "15.7.3",
    "@types/react": "16.9.11",
    "@types/react-dom": "16.9.4",
    "concurrently": "5.0.0",
    "css-loader": "3.2.0",
    "file-loader": "4.2.0",
    "less": "3.10.3",
    "less-loader": "5.0.0",
    "uglifyjs-webpack-plugin": "2.2.0",
    "mini-css-extract-plugin": "0.8.0",
    "optimize-css-assets-webpack-plugin": "5.0.3",
    "raw-loader": "3.1.0",
    "rimraf": "3.0.0",
    "style-loader": "1.0.0",
    "typescript": "3.7.2",
    "url-loader": "2.2.0",
    "watch": "1.0.2",
    "webpack": "4.41.2",
    "webpack-cli": "3.3.10",
    "webpack-dev-server": "3.9.0",
    "whatwg-fetch": "3.0.0"
  },
  "resolutions": {
    "@types/**/@types/react": "16.9.11"
  }
}
