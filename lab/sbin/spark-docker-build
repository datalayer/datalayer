if [ -z "$1" ]
then
  export FLAVOR=2.4
else
  export FLAVOR=$1
fi

echo -e $BOLD"Building Spark Docker Images for flavor '$FLAVOR'"$NOBOLD
echo

case "$FLAVOR" in

  2.4)
    cd $DLAOPT/spark && \
      ./bin/docker-image-tool.sh -r docker.io/datalayer -t 2.4.0 -p ./kubernetes/dockerfiles/spark/bindings/python/Dockerfile build && \
      docker tag spark-base:latest datalayer/spark-base:2.4.0
    ;;

  2.2)
    cd $DLAOPT/spark && \
      ./sbin/build-push-docker-images.sh -r docker.io/datalayer -t 2.2.0 build && \
      docker tag spark-base:latest datalayer/spark-base:2.2.0
    ;;

  *)
    echo "Unknown Flavor: $FLAVOR" 1>&2
    echo
    exit 1

esac
