# echo -e $BOLD$GREEN$DLA_ECHO_SEPARATOR$NOCOLOR$NOBOLD

print_picto() {
    echo -e  """$1$BOLD$2$RED
data-pirats 10100010100 -=::>$NOCOLOR$NOBOLD
"""
}

print_picto "$YELLOW" "$picto_1"
print_picto "$GREEN" "$picto_2"
print_picto "$BLUE" "$YELLOW" "$picto_3"
print_picto "$ORANGE" "$picto_4"
print_picto "$FAINT" "$picto_5"
print_picto "$WHITE_BCK" "$picto_6"
print_picto "$GREEN_BCK" "$picto_7"
print_picto "$RED" "$picto_7"
print_picto "$YELLOW" "$picto_7"
print_picto "$YELLOW" "$picto_8"
print_picto "$YELLOW" "$picto_9"
