{
  "name": "@datalayer/jupyterlab-twitter",
  "version": "0.0.3",
  "description": "JupyterLab Extension for Twitter",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datalayer/datalayer/tree/master/src/jupyterlab/twitter"
  },
  "author": "Datalayer <info@datalayer.io>",
  "keywords": [
    "datalayer",
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "twitter"
  ],
  "homepage": "https://github.com/datalayer/datalayer#README",
  "bugs": {
    "url": "https://github.com/datalayer/datalayer/issues"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/*.css",
    "style/images/*.svg"
  ],
  "main": "lib/index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "prepublish": "npm run build",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@datalayer/widgets": "0.0.3",
    "@jupyterlab/application": "^2.0.0-alpha.1",
    "@jupyterlab/apputils": "^2.0.0-alpha.1",
    "@jupyterlab/cells": "^2.0.0-alpha.1",
    "@jupyterlab/console": "^2.0.0-alpha.1",
    "@jupyterlab/coreutils": "^4.0.0-alpha.1",
    "@jupyterlab/filebrowser": "^2.0.0-alpha.1",
    "@jupyterlab/mainmenu": "^2.0.0-alpha.1",
    "@jupyterlab/notebook": "^2.0.0-alpha.1",
    "@jupyterlab/terminal": "^2.0.0-alpha.1",
    "@jupyterlab/theming": "0.9.0",
    "es6-promise": "4.2.8",
    "@phosphor/widgets": "1.9.3",
    "better-react-spinkit": "2.0.4",
    "html2canvas": "1.0.0-alpha.12",
    "nbdime": "5.0.1",
    "prop-types": "15.7.2",
    "react": "16.11.0",
    "react-dom": "16.11.0",
    "react-redux": "7.1.1",
    "react-redux-toastr": "7.6.1",
    "react-twitter-widgets": "1.7.1",
    "redux": "4.0.4",
    "redux-thunk": "2.3.0",
    "react-toggle-display": "^2.2.0"
  },
  "devDependencies": {
    "@types/prop-types": "15.7.3",
    "@types/react-redux": "7.1.4",
    "@types/react": "16.9.11",
    "@types/react-dom": "16.9.3",
    "rimraf": "3.0.0",
    "typescript": "3.7.1-rc"
  },
  "jupyterlab": {
    "extension": true,
    "discovery": {
      "server": {
        "managers": [
          "pip"
        ],
        "base": {
          "name": "jupyterlab_twitter"
        }
      }
    }
  },
  "resolutions": {
    "**/@types/react": "16.9.11",
    "**/@types/react-dom": "16.9.3"
  }
}
