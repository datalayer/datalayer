    "@storybook/addon-docs": "6.0.10",
    "@storybook/source-loader": "6.0.10",
    "@types/jest": "24.0.18",
    "@types/node": "~12.12.21",
    "@types/react": "16.9.16",
    "@types/react-dom": "16.9.4",
    "@types/webpack": "4.41.12",
    "@types/webpack-env": "^1.14.1",
    "awesome-typescript-loader": "^5.2.1",
