{
  "name": "@datalayer/minilab-storybook",
  "version": "0.0.1",
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "webpack-dev-server",
    "tsc": "tsc",
    "build": "concurrently \"tsc\" \"gulp resources-to-lib\"",
