DSP_REPOS=()
for repo in $DSP_REPOS_ORIGIN_REMOTE; do
  name=$(cut -d'|' -f1 <<<$repo)
  origin=$(cut -d'|' -f2 <<<$repo)
  remote=$(cut -d'|' -f3 <<<$repo)
  branch=$(cut -d'|' -f4 <<<$repo)
  DSP_REPOS+=($name)
  DSP_REPOS+=($origin)
  DSP_REPOS+=($remote)
  DSP_REPOS+=($branch)
done
