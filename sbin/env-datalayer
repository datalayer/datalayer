#     sudo apt install -y npm
#     npm install -g yarn
}

macos_pre() {
  echo
  echo -e $WHITE_BCK"DSP PRE-INSTALL ON MAC OSX"$NOCOLOR
  echo
}

# case "${OS}" in
#     LINUX)     linux_pre;;
#     MACOS)     macos_pre;;
#     *)         echo "Unsupported operating system ${OS}"
# esac

# ------------------------------------

mkdir -p $DLAHOME/var/datalayer
chown -R $USER:$(id -gn) $DLAHOME/srv/jupyterhub

openssl rand -hex 32 > $DLAHOME/srv/jupyterhub/jupyterhub_auth_token
chmod 600 $DLAHOME/srv/jupyterhub/jupyterhub_auth_token
openssl rand -hex 32 > $DLAHOME/srv/jupyterhub/jupyterhub_cookie_secret
chmod 600 $DLAHOME/srv/jupyterhub/jupyterhub_cookie_secret

mkdir -p $DLAHOME/var/log
touch $DLAHOME/var/log/datalayer.log
chown -R $USER:$(id -gn) $DLAHOME/var/log/datalayer.log

# ------------------------------------

# rm -fr ~/.yarn-cache
yarn config set cache-folder ~/.yarn-cache

# ------------------------------------

# sudo npm install -g configurable-http-proxy
# npm install configurable-http-proxy

# ------------------------------------

install_iam() {
    echo
    echo -e $WHITE_BCK"INSTALLING IAM"$NOCOLOR
    echo
    cd $DLAHOME/apps/iam && \
    make clean && \
    make install && \
    make build && \
    make dev
}

install_iam

# ------------------------------------

install_library() {
    echo
    echo -e $WHITE_BCK"INSTALLING LIBRARY"$NOCOLOR
    echo
    cd $DLAHOME/apps/library && \
    make clean && \
    make install && \
    make build && \
    make dev
}

install_library

